# Supabase — get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only — used by service.ts for privileged operations (admin user creation,
# external webhook intake). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Optional — public app host for portal links (defaults in next.config.mjs)
# NEXT_PUBLIC_APP_HOST=tmmt-c919-two.vercel.app
# NEXT_PUBLIC_PORTAL_URL=https://tmmt-c919-two.vercel.app

# Optional — for the public /api/intake webhook so Airtable / GHL / Zapier / n8n can POST
# anonymous submissions. Send as header: X-Intake-Secret
INTAKE_WEBHOOK_SECRET=change-me

# Webhooks — GHL / Airtable CRM sync (see INTEGRATIONS/GHL_WEBHOOK_SETUP.md)
GHL_WEBHOOK_SECRET=
# Set to "false" to skip creating client portal reminders on GHL stage webhooks
# GHL_CLIENT_ALERTS=false
GHL_OVERDUE_WEBHOOK_SECRET=
SYNC_WEBHOOK_SECRET=
AIRTABLE_LEADS_TABLE=Leads

# n8n — generic automation ingress (header: X-N8N-Secret)
N8N_WEBHOOK_SECRET=

# AIXMOS agent panel — /api/agents/evaluate (header: X-Agent-Secret)
AGENT_WEBHOOK_SECRET=

# Ops command — Cursor / automations (Authorization: Bearer …)
# Generate: openssl rand -hex 32
# Also used by /internal/assistant when calling /api/ops/command from scripts
OPS_COMMAND_SECRET=

# GHL stage webhooks — auto-verify CRM, assign staff, advance case (default on)
# Set to "false" to disable automatic case updates from GHL stage changes
GHL_AUTO_OPS=true
# Default internal assignee when a stage rule includes assignee_email
GHL_DEFAULT_ASSIGNEE_EMAIL=management@tmmtrentals.net
# Optional — override per-stage rules (minified JSON)
# GHL_STAGE_OPS_JSON={"payment_pending":{"assignee_email":"ops@tmmtrentals.net","case_status":"task_assignment"}}

# Optional — ClickUp/Airtable/GHL outbound
CLICKUP_API_TOKEN=
CLICKUP_TEAM_ID=
CLICKUP_DEFAULT_LIST_ID=
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
GHL_API_KEY=
GHL_LOCATION_ID=
# Minified JSON from INTEGRATIONS/GHL_PIPELINE_STAGE_MAP.example.json
GHL_PIPELINE_STAGE_MAP_JSON=
