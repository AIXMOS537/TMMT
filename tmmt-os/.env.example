# Supabase — get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only — used by service.ts for privileged operations (admin user creation,
# external webhook intake). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Optional — for the public /api/intake webhook so Airtable / GHL / Zapier can POST
# anonymous submissions without leaking the service-role key. Generate any random
# string and configure your webhook senders to include it as the X-Intake-Secret header.
INTAKE_WEBHOOK_SECRET=change-me

# Optional — ClickUp/Airtable/GHL placeholders for future integrations
CLICKUP_API_TOKEN=
CLICKUP_DEFAULT_LIST_ID=
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
GHL_API_KEY=
