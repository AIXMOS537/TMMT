# Supabase — get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only — used by service.ts for privileged operations (admin user creation,
# external webhook intake). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Optional — for the public /api/intake webhook so Airtable / GHL / Zapier can POST
# anonymous submissions without leaking the service-role key. Generate any random
# string and configure your webhook senders to include it as the X-Intake-Secret header.
INTAKE_WEBHOOK_SECRET=change-me

# Optional — public app host (defaults in next.config.mjs)
# NEXT_PUBLIC_APP_HOST=tmmt-c919-two.vercel.app
# NEXT_PUBLIC_PORTAL_URL=https://tmmt-c919-two.vercel.app

# Overdue collections — n8n → TMMT OS (AUTOMATIONS/GHL_OVERDUE_WORKFLOW_SETUP.md)
GHL_OVERDUE_WEBHOOK_SECRET=

# n8n ingress for overdue automation (header: X-N8N-Secret)
N8N_WEBHOOK_SECRET=


# Optional — ClickUp/Airtable/GHL placeholders for future integrations
CLICKUP_API_TOKEN=
CLICKUP_DEFAULT_LIST_ID=
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
GHL_API_KEY=
GHL_LOCATION_ID=
# From INTEGRATIONS/GHL_PIPELINE_STAGE_MAP.example.json (minified)
GHL_PIPELINE_STAGE_MAP_JSON=
